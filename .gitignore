# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
bun-debug.log*

# ----- Node / frontend dependencies -----
node_modules/

# ----- Build outputs -----
# Cargo workspace (root, src-tauri/, crates/*/ — all caught by unanchored)
target/
**/*.rs.bk

# Vite / Tauri frontend dist
dist/
dist-ssr/
*.local

# Tauri-generated artifacts (regenerated by tauri-build on every build)
src-tauri/gen/

# Tauri Windows MSI bundling scratch dir
src-tauri/WixTools/

# ----- Bundled application binaries (when built ad-hoc outside target/) -----
*.app
*.dSYM
*.dmg
*.deb
*.rpm
*.AppImage
*.msi
*.exe

# ----- Local environment / secrets -----
.env
.env.local
.env.*.local

# ----- Local planning / agent scratch -----
.scratch/
.sc/
.claude/
.worktrees/
CONTEXT.md

# Project docs: keep shared architecture/design/agent docs, ignore local ADR/dev drafts.
docs/*
!docs/agents/
!docs/agents/**
!docs/architecture/
!docs/architecture/**
!docs/design/
!docs/design/**
docs/adr/
docs/dev/

